# ArbiX Web — environment variables
# Copy to .env.local and fill in the values.

# URL of the NestJS API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000

# URL for Socket.io WebSocket connection (same host as API)
NEXT_PUBLIC_WS_URL=http://localhost:4000

# Groq API key for the ArbiX Assistant chatbot (server-side only)
GROQ_API_KEY=
